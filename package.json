{
  "name": "pogchatter",
  "version": "0.1.0",
  "private": true,
  "description": "Chatterino-style unified Twitch + YouTube Live chat client",
  "license": "MIT",
  "author": "0x43687269735079",
  "repository": "github:0x43687269735079/pogchatter",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "chatlog": "node scripts/simple-chatlog.mjs",
    "build:unpack": "electron-vite build && electron-builder --dir",
    "build:win": "electron-vite build && ELECTRON_BUILDER_7Z_FILTER=BCJ2 electron-builder --win",
    "build:mac": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "devDependencies": {
    "@emoji-mart/data": "1.2.1",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@twurple/api": "8.1.4",
    "@twurple/auth": "8.1.4",
    "@twurple/chat": "8.1.4",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "42.3.0",
    "electron-builder": "26.15.2",
    "electron-vite": "5.0.0",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "6.0.3",
    "undici": "8.3.0",
    "vite": "7.3.3",
    "vitest": "4.1.7",
    "youtubei.js": "17.0.1"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.3",
  "desktopName": "Pogchatter.desktop",
  "productName": "Pogchatter"
}
